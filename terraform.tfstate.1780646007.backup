            "values": [
              "\"alertmanager\":\n  \"enabled\": false\n\"grafana\":\n  \"adminPassword\": \"Siseon2026!\"\n  \"dashboardProviders\":\n    \"dashboardproviders.yaml\":\n      \"apiVersion\": 1\n      \"providers\":\n      - \"disableDeletion\": true\n        \"editable\": false\n        \"folder\": \"\\U0001F4CA 인프라 모니터링\"\n        \"name\": \"infra-templates\"\n        \"options\":\n          \"path\": \"/var/lib/grafana/dashboards/infra-templates\"\n        \"orgId\": 1\n        \"type\": \"file\"\n      - \"disableDeletion\": true\n        \"editable\": true\n        \"folder\": \"\\U0001F4CA 인프라 모니터링\"\n        \"name\": \"infra-custom\"\n        \"options\":\n          \"path\": \"/var/lib/grafana/dashboards/infra-custom\"\n        \"orgId\": 1\n        \"type\": \"file\"\n  \"dashboards\":\n    \"infra-custom\":\n      \"stockops-infra\":\n        \"json\": \"{\\\"panels\\\":[{\\\"datasource\\\":{\\\"type\\\":\\\"prometheus\\\",\\\"uid\\\":\\\"prometheus\\\"},\\\"fieldConfig\\\":{\\\"defaults\\\":{\\\"max\\\":100,\\\"min\\\":0,\\\"thresholds\\\":{\\\"mode\\\":\\\"absolute\\\",\\\"steps\\\":[{\\\"color\\\":\\\"green\\\",\\\"value\\\":null},{\\\"color\\\":\\\"yellow\\\",\\\"value\\\":60},{\\\"color\\\":\\\"red\\\",\\\"value\\\":80}]},\\\"unit\\\":\\\"percent\\\"}},\\\"gridPos\\\":{\\\"h\\\":5,\\\"w\\\":4,\\\"x\\\":0,\\\"y\\\":0},\\\"id\\\":1,\\\"targets\\\":[{\\\"expr\\\":\\\"100\n          - (avg(irate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)\\\",\\\"legendFormat\\\":\\\"CPU\\\"}],\\\"title\\\":\\\"\\U0001F5A5️\n          클러스터 CPU 사용률\\\",\\\"type\\\":\\\"gauge\\\"},{\\\"datasource\\\":{\\\"type\\\":\\\"prometheus\\\",\\\"uid\\\":\\\"prometheus\\\"},\\\"fieldConfig\\\":{\\\"defaults\\\":{\\\"max\\\":100,\\\"min\\\":0,\\\"thresholds\\\":{\\\"mode\\\":\\\"absolute\\\",\\\"steps\\\":[{\\\"color\\\":\\\"green\\\",\\\"value\\\":null},{\\\"color\\\":\\\"yellow\\\",\\\"value\\\":60},{\\\"color\\\":\\\"red\\\",\\\"value\\\":80}]},\\\"unit\\\":\\\"percent\\\"}},\\\"gridPos\\\":{\\\"h\\\":5,\\\"w\\\":4,\\\"x\\\":4,\\\"y\\\":0},\\\"id\\\":2,\\\"targets\\\":[{\\\"expr\\\":\\\"100\n          - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100)\\\",\\\"legendFormat\\\":\\\"Memory\\\"}],\\\"title\\\":\\\"\\U0001F4BE\n          클러스터 메모리 사용률\\\",\\\"type\\\":\\\"gauge\\\"},{\\\"datasource\\\":{\\\"type\\\":\\\"prometheus\\\",\\\"uid\\\":\\\"prometheus\\\"},\\\"fieldConfig\\\":{\\\"defaults\\\":{\\\"thresholds\\\":{\\\"mode\\\":\\\"absolute\\\",\\\"steps\\\":[{\\\"color\\\":\\\"green\\\",\\\"value\\\":null}]},\\\"unit\\\":\\\"short\\\"}},\\\"gridPos\\\":{\\\"h\\\":5,\\\"w\\\":4,\\\"x\\\":8,\\\"y\\\":0},\\\"id\\\":3,\\\"targets\\\":[{\\\"expr\\\":\\\"count(kube_pod_status_phase{phase='Running'})\\\",\\\"legendFormat\\\":\\\"Running\\\"}],\\\"title\\\":\\\"✅\n          Running Pods\\\",\\\"type\\\":\\\"stat\\\"},{\\\"datasource\\\":{\\\"type\\\":\\\"prometheus\\\",\\\"uid\\\":\\\"prometheus\\\"},\\\"fieldConfig\\\":{\\\"defaults\\\":{\\\"thresholds\\\":{\\\"mode\\\":\\\"absolute\\\",\\\"steps\\\":[{\\\"color\\\":\\\"green\\\",\\\"value\\\":null},{\\\"color\\\":\\\"red\\\",\\\"value\\\":1}]},\\\"unit\\\":\\\"short\\\"}},\\\"gridPos\\\":{\\\"h\\\":5,\\\"w\\\":4,\\\"x\\\":12,\\\"y\\\":0},\\\"id\\\":4,\\\"targets\\\":[{\\\"expr\\\":\\\"count(kube_pod_status_phase{phase='Failed'})\n          or vector(0)\\\",\\\"legendFormat\\\":\\\"Failed\\\"}],\\\"title\\\":\\\"\\U0001F6A8 Failed\n          Pods\\\",\\\"type\\\":\\\"stat\\\"},{\\\"datasource\\\":{\\\"type\\\":\\\"prometheus\\\",\\\"uid\\\":\\\"prometheus\\\"},\\\"fieldConfig\\\":{\\\"defaults\\\":{\\\"thresholds\\\":{\\\"mode\\\":\\\"absolute\\\",\\\"steps\\\":[{\\\"color\\\":\\\"blue\\\",\\\"value\\\":null}]},\\\"unit\\\":\\\"short\\\"}},\\\"gridPos\\\":{\\\"h\\\":5,\\\"w\\\":4,\\\"x\\\":16,\\\"y\\\":0},\\\"id\\\":5,\\\"targets\\\":[{\\\"expr\\\":\\\"count(kube_node_info)\\\",\\\"legendFormat\\\":\\\"Nodes\\\"}],\\\"title\\\":\\\"\\U0001F5A7\n          Node 수\\\",\\\"t